# Backend Production Environment
# Copy this to .env.production and fill in your values
# IMPORTANT: .env.production files are IGNORED by git (.gitignore) - never commit real credentials

# ============ DATABASE ============
# MongoDB Connection URL
# For Docker: mongodb://admin:PASSWORD@mongo:27017 (mongo is service name)
# For Hostinger: mongodb://admin:PASSWORD@mongodb-host:27017
MONGO_URL=mongodb://admin:YOUR_MONGO_PASSWORD@mongo:27017
DB_NAME=ge_question_bank

# ============ CORS & SECURITY ============
# Allowed origins for API requests (comma-separated)
# Production: https://apps.geniuseducation.co.uk
# Test/Dev: * (allow all)
CORS_ORIGINS=https://apps.geniuseducation.co.uk,http://localhost

# ============ AI CLASSIFICATION ============
# Google Gemini API Key
# Used for: Topic classification, difficulty tagging (1 call per PDF)
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# ============ PDF EXTRACTION ============
# Mathpix API Credentials
# Used for: Extracting text, LaTeX, diagrams, tables from PDFs
# Get from: https://www.mathpix.com/dashboard
MATHPIX_APP_ID=YOUR_MATHPIX_APP_ID
MATHPIX_APP_KEY=YOUR_MATHPIX_APP_KEY

# ============ STORAGE (Optional) ============
# Emergent LLM Cloud Storage API Key
# Leave empty to use local filesystem storage (/uploads folder)
# Get from: https://emergentapi.com
EMERGENT_LLM_KEY=
