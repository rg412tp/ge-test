# Docker Compose Environment
# Copy this to .env and fill in your values
# IMPORTANT: .env files are IGNORED by git (.gitignore) - never commit real credentials

# Frontend backend URL (must match your domain or IP:port)
REACT_APP_BACKEND_URL=https://apps.geniuseducation.co.uk

# MongoDB root credentials (used to initialize MongoDB container)
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=YOUR_SECURE_MONGO_PASSWORD_HERE
